generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model School {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  code      String   @unique
  district  String?
  taluka    String?
  city      String?
  pincode   String?
  address   String?
  phone     String?
  alternatePhone String?
  email     String?
  website   String?
  principalName  String?
  schoolType     String?
  boardAffiliation String?
  udiseCode      String?  @unique
  isActive  Boolean  @default(true)

  users           User[]
  students        Student[]
  staff           Staff[]
  classes         SchoolClass[]
  settings        SchoolSettings?
  subscription    SchoolSubscription?
  payments        SchoolPayment[]
  bulkSubmissions BulkSubmission[]
  automationJobs  AutomationJob[]
  smsInbox        SmsInboxMessage[]
  financialYears  FinancialYear[]
  accounts        Account[]
  vouchers        Voucher[]
  exams           Exam[]
  auditSessions   CaAuditSession[]
  caAssignments   CaSchoolAssignment[]
  idCardShareLinks IdCardShareLink[]
  attendanceMonths StudentAttendanceMonth[]
  staffAttendanceMonths StaffAttendanceMonth[]
  staffPayrolls StaffPayroll[]
  salaryStatementRows SalaryStatementRow[]
  staffSalarySlipRows StaffSalarySlipRow[]
  staffIncomeTaxForms StaffIncomeTaxForm[]
  chatRooms     ChatRoom[]
  generalRegisterEntries GeneralRegisterEntry[]
  dailyAttendanceBooks DailyAttendanceBook[]
  timetableEntries TimetableEntry[]
  timetableConfigs SchoolTimetableConfig[]
  timetableReleases ClassTimetableRelease[]
  notifications Notification[]

  @@index([isActive])
  @@index([district])
  @@map("school")
}

model SchoolSubscription {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  schoolId  String   @unique
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  planName             String   @default("standard")
  contractNumber       String?
  contractValue        Decimal? @db.Decimal(12, 2)
  contractStartDate    DateTime?
  contractEndDate      DateTime?
  contractDocumentPath String?
  contractNotes        String?  @db.Text
  enabledFeatures      Json     @default("[]")
  paymentStatus        String   @default("pending")
  totalAmount          Decimal? @db.Decimal(12, 2)
  paidAmount           Decimal  @default(0) @db.Decimal(12, 2)
  nextDueDate          DateTime?

  @@map("schoolsubscription")
}

model SchoolPayment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  amount        Decimal  @db.Decimal(12, 2)
  paymentDate   DateTime
  paymentMethod String?
  referenceNo   String?
  notes         String?
  receivedBy    String?

  @@index([schoolId])
  @@index([paymentDate])
  @@map("schoolpayment")
}

model PlatformSettings {
  id        String   @id @default("platform")
  updatedAt DateTime @updatedAt

  emailEnabled      Boolean  @default(false)
  smtpHost          String?
  smtpPort          Int      @default(587)
  smtpSecure        Boolean  @default(false)
  smtpUser          String?
  smtpPasswordEnc   String?  @db.Text
  smtpFromName      String?  @default("SHS Education Portal")
  smtpFromEmail     String?
  smtpReplyTo       String?
  smtpLastTestAt    DateTime?
  smtpLastTestOk    Boolean?
  smtpLastTestError String?  @db.Text

  @@map("platformsettings")
}

model PendingAdminEmailVerification {
  email      String    @id
  adminName  String
  schoolName String?
  otpHash    String
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  @@map("pendingadminemailverification")
}

/** Super-admin school register wizard — draft keyed by unique school code */
model SchoolRegistrationDraft {
  code      String   @id
  step      Int      @default(0)
  payload   Json
  updatedAt DateTime @updatedAt

  @@map("schoolregistrationdraft")
}

model User {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  email        String    @unique
  passwordHash String
  name         String
  role         String
  schoolId     String?
  school       School?   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staffId      String?   @unique
  staff        Staff?    @relation(fields: [staffId], references: [id], onDelete: SetNull)
  studentId    String?   @unique
  student      Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  failedLoginCount Int   @default(0)
  lockedUntil  DateTime?
  emailVerified            Boolean   @default(false)
  emailVerificationToken   String?   @unique
  emailVerificationExpires DateTime?
  emailVerifiedAt          DateTime?

  vouchersCreated Voucher[]      @relation("VoucherCreatedBy")
  auditActions    AuditAction[]
  caSchoolAssignments CaSchoolAssignment[]
  fySubmissions   FinancialYear[] @relation("FySubmittedBy")
  chatParticipants ChatParticipant[]
  chatMessagesSent ChatMessage[] @relation("ChatMessageSender")
  notifications    Notification[]

  @@index([schoolId])
  @@index([role])
  @@map("user")
}

model SchoolSettings {
  id                 String @id @default(cuid())
  schoolId           String? @unique
  school             School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolName         String @default("My School")
  schoolAddress      String?
  schoolPhone        String?
  schoolEmail        String?
  academicYear       String @default("2025-26")
  logoPath           String?
  idCardPrimaryColor String @default("#e91e8c")
  idCardAccentColor  String @default("#1e3a8a")
  tagline            String?
  /** School SJED portal login — ek baar save, sab students ke liye same session */
  dgSjedUsername     String?
  dgSjedPassword     String?
  /** Post-Matric Citizen portal (optional) */
  dgCitizenLoginId   String?
  dgCitizenPassword  String?
  dgCitizenLoginMethod String? @default("mobile")
  /** Phone SMS webhook secret — SMS Forwarder app is token se connect */
  smsInboxToken      String?  @unique
  /** DG OTP wala registered mobile — phone bridge link is number se connect */
  dgOtpMobile        String?

  @@map("schoolsettings")
}

model IdCardShareLink {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  schoolId     String
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  slug         String    @unique
  username     String
  passwordHash String
  label        String?
  classId      String?
  standard     String?
  section      String?
  academicYear String    @default("2025-26")
  expiresAt    DateTime?
  isActive     Boolean   @default(true)
  lastAccessAt DateTime?
  accessCount  Int       @default(0)
  createdById  String?

  @@index([schoolId])
  @@map("idcardsharelink")
}

model StudentAttendanceMonth {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId      String?
  month        Int
  year         Int
  daysJson     String   @db.Text
  monthTotal   Int      @default(0)
  prevTotal    Int      @default(0)
  cumulative   Int      @default(0)
  schoolFee    String?
  termFee      String?
  admissionFee String?
  otherFee     String?
  note         String?

  @@unique([studentId, month, year])
  @@index([schoolId, classId, month, year])
  @@map("studentattendancemonth")
}

model SmsInboxMessage {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sender     String?
  body       String   @db.Text
  otpCode    String?
  consumed   Boolean  @default(false)

  @@index([schoolId, createdAt])
  @@index([schoolId, consumed])
  @@map("smsinboxmessage")
}

model Staff {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  schoolId      String?
  school        School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  employeeId    String?
  firstName     String
  lastName      String
  designation   String
  department    String?
  mobileNumber  String
  email         String?
  gender        String?
  dateOfJoining String?
  dateOfBirth   String?
  panNumber     String?
  gpfCpfNo      String?
  aadhaarNumber String?
  qualification String?
  /** e.g. "LEVEL-8 44900-142400" or "FIX PAY" */
  payLevel      String?
  isActive      Boolean  @default(true)
  photoPath     String?
  /** Monthly salary structure */
  monthlySalary   Float?
  hra             Float?   @default(0)
  conveyance      Float?   @default(0)
  pfDeduction     Float?   @default(0)
  bankName        String?
  bankAccount     String?
  ifscCode        String?
  classes       SchoolClass[] @relation("ClassTeacher")
  user          User?
  attendanceMonths StaffAttendanceMonth[]
  payrolls       StaffPayroll[]
  timetableEntries TimetableEntry[]
  salarySlipRows StaffSalarySlipRow[]
  incomeTaxForms StaffIncomeTaxForm[]

  @@unique([schoolId, employeeId])
  @@index([schoolId])
  @@index([isActive])
  @@index([designation])
  @@map("staff")
}

model StaffAttendanceMonth {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staffId     String
  staff       Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  month       Int
  year        Int
  daysJson    String   @db.Text
  presentDays Int      @default(0)
  absentDays  Int      @default(0)
  leaveDays   Int      @default(0)
  halfDays    Int      @default(0)
  note        String?

  @@unique([staffId, month, year])
  @@index([schoolId, month, year])
  @@map("staffattendancemonth")
}

model StaffPayroll {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  schoolId      String
  school        School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staffId       String
  staff         Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  month         Int
  year          Int
  workingDays   Int       @default(0)
  presentDays   Int       @default(0)
  absentDays    Int       @default(0)
  grossSalary   Float     @default(0)
  deductions    Float     @default(0)
  netSalary     Float     @default(0)
  paymentStatus String    @default("pending")
  paidAt        DateTime?
  note          String?

  @@unique([staffId, month, year])
  @@index([schoolId, month, year, paymentStatus])
  @@map("staffpayroll")
}

/**
 * Annual salary statement — one row per month per staff category
 * (Secondary Teaching / Higher Secondary Teaching / Non-Teaching / Peon)
 */
model SalaryStatementRow {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  /** e.g. "2023-24" */
  financialYear String
  /** secondary | higher_secondary | non_teaching | peon */
  category      String
  /** 1–12 (statement order: Mar=3 … Feb=2) */
  month         Int
  year          Int
  basic         Float    @default(0)
  da            Float    @default(0)
  hra           Float    @default(0)
  ma            Float    @default(0)
  fpa           Float    @default(0)
  hndA          Float    @default(0)
  suA           Float    @default(0)
  caA           Float    @default(0)
  wa            Float    @default(0)
  prA           Float    @default(0)
  bonus         Float    @default(0)
  daArrears     Float    @default(0)
  salaryArrears Float    @default(0)

  @@unique([schoolId, financialYear, category, month])
  @@index([schoolId, financialYear])
  @@map("salarystatementrow")
}

/** Per-employee annual salary slip — one row per month (Apr–Mar) */
model StaffSalarySlipRow {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staffId       String
  staff         Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  /** e.g. "2025-26" */
  financialYear String
  month         Int
  year          Int
  /** Salary side */
  basic         Float    @default(0)
  da            Float    @default(0)
  hra           Float    @default(0)
  mediAll       Float    @default(0)
  daArrears     Float    @default(0)
  salaryArrears Float    @default(0)
  otherArrears  Float    @default(0)
  cashAll       Float    @default(0)
  washAll       Float    @default(0)
  fpAll         Float    @default(0)
  phAll         Float    @default(0)
  /** Deduction side */
  gpfCpf        Float    @default(0)
  iTax          Float    @default(0)
  pTax          Float    @default(0)
  gruInsu       Float    @default(0)
  otherDed      Float    @default(0)

  @@unique([staffId, financialYear, month])
  @@index([schoolId, financialYear])
  @@map("staffsalarysliprow")
}

/** Per-employee income tax computation form (Avak Vera) — inputs stored as JSON */
model StaffIncomeTaxForm {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staffId       String
  staff         Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  /** e.g. "2025-26" */
  financialYear String
  dataJson      String   @db.Text

  @@unique([staffId, financialYear])
  @@index([schoolId, financialYear])
  @@map("staffincometaxform")
}

model SchoolClass {
  id                  String   @id @default(cuid())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  schoolId            String?
  school              School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name                String
  standard            String
  section             String
  /** Arts / Commerce for 11–12; empty for 9–10 */
  stream              String   @default("")
  academicYear        String   @default("2025-26")
  institutionName     String?
  institutionDistrict String?
  classTeacherId      String?
  classTeacher        Staff?   @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  students            Student[]
  timetableEntries    TimetableEntry[]
  timetableReleases   ClassTimetableRelease[]
  classSubjects       ClassSubject[]

  @@unique([schoolId, standard, section, stream, academicYear])
  @@index([schoolId])
  @@index([standard])
  @@index([academicYear])
  @@map("schoolclass")
}

model ClassSubject {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  classId   String
  class     SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  name      String
  code      String
  shortName String      @default("")
  /** numeric | grade */
  type      String      @default("numeric")
  maxMarks  Int         @default(100)
  sortOrder Int         @default(0)
  isActive  Boolean     @default(true)

  @@unique([classId, code])
  @@index([classId])
  @@map("classsubject")
}

model Student {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  firstName        String
  middleName       String?
  surname          String
  firstNameGu      String?
  middleNameGu     String?
  surnameGu        String?
  aadhaarName      String
  aadhaarNameGu    String?
  dateOfBirth      String
  gender           String
  aadhaarNumber    String
  rationCardNumber String?
  mobileNumber     String
  email            String?
  motherName       String
  fatherName       String
  motherNameGu     String?
  fatherNameGu     String?
  guardianName     String?
  guardianNameGu   String?
  category         String
  caste            String?
  religion         String
  maritalStatus    String  @default("Unmarried")
  parentOccupation String
  isOrphan         Boolean @default(false)
  annualFamilyIncome Float

  classId              String?
  schoolClass          SchoolClass? @relation(fields: [classId], references: [id])
  rollNumber           String?
  grNumber             String?
  section              String?
  standard             String?
  childUid             String?
  bloodGroup           String?
  idCardValidUpto      String?
  idPhotoProcessedPath String?

  currentAddress     String   @db.Text
  currentDistrict    String
  currentCity        String
  currentPincode     String
  permanentAddress   String   @db.Text
  permanentDistrict  String
  permanentCity      String
  permanentPincode   String
  habitationType     String  @default("Own")
  familySize         Int     @default(4)
  residentType       String  @default("Rural")
  isHosteler         Boolean @default(false)
  hostelType         String?
  hostelName         String?

  scholarshipScheme    String
  financialYear        String
  courseType           String
  courseName           String
  institutionDistrict  String
  institutionName      String
  currentYear          String
  admissionType        String  @default("Regular")
  startDate            String?
  completionDate       String?
  board10th            String
  percentage10th       Float
  year10th             String
  /** GSEB SSC seat — prefix A/B/C/S/P + 7 digit number */
  sscSeatPrefix        String?  @default("A")
  sscSeatNumber        String?
  board12th            String?
  percentage12th       Float?
  year12th             String?
  hscSeatPrefix        String?
  hscSeatNumber        String?
  gsebFetchedAt        DateTime?
  gsebResultJson       String?  @db.Text
  previousQualification String?

  bankName          String
  branchName        String
  accountNumber     String
  ifscCode          String
  accountHolderName String

  dgLoginId       String?
  dgPassword      String?
  dgLoginMethod   String?  @default("mobile")

  photoPath           String?
  aadhaarDocPath      String?
  incomeCertPath      String?
  casteCertPath       String?
  marksheet10Path     String?
  marksheet12Path     String?
  bankPassbookPath    String?
  feeReceiptPath      String?

  lastAutomationAt    DateTime?
  lastAutomationLog   String?  @db.Text

  status           String  @default("draft")
  admissionStatus  String  @default("pending")
  verifiedAt       DateTime?
  verifiedBy       String?
  submissionDate   DateTime?
  notes            String?  @db.Text
  validationErrors String?  @db.Text

  user         User?
  examResults  ExamResult[]
  reportCards  ReportCard[]
  attendanceMonths StudentAttendanceMonth[]
  generalRegisterEntries GeneralRegisterEntry[]

  @@unique([schoolId, aadhaarNumber])
  @@index([schoolId])
  @@index([status])
  @@index([category])
  @@index([scholarshipScheme])
  @@index([classId])
  @@index([standard])
  @@index([section])
  @@map("student")
}

model GeneralRegisterEntry {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  schoolId        String
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId       String?
  student         Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  academicYear    String
  grNumber        String
  surname         String   @default("")
  firstName       String   @default("")
  fatherName      String   @default("")
  motherName      String   @default("")
  religionCaste   String   @default("")
  birthPlaceJson  String   @default("[]") @db.Text
  dateOfBirth     String   @default("")
  dobWordsGu      String   @default("")
  childUidDigits  String   @default("")
  lastSchool      String   @default("")
  udiseDigits     String   @default("")
  admissionDate   String   @default("")
  feeStatus       String   @default("")
  standard        String   @default("")
  section         String   @default("")
  progress        String   @default("")
  conduct         String   @default("સારી")
  leavingDate     String   @default("")
  leavingStdClass String   @default("")
  lcIssueDate     String   @default("")
  remarks         String   @default("") @db.Text

  @@unique([schoolId, academicYear, grNumber])
  @@index([schoolId, academicYear])
  @@index([studentId])
  @@map("generalregisterentry")
}

model TimetableEntry {
  id           String      @id @default(cuid())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  schoolId     String
  school       School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId      String
  class        SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  academicYear String      @default("2025-26")
  dayOfWeek    Int
  periodIndex  Int
  subject      String
  teacherId    String?
  teacher      Staff?      @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  room         String?

  @@unique([schoolId, classId, academicYear, dayOfWeek, periodIndex])
  @@index([schoolId, classId, academicYear])
  @@map("timetableentry")
}

model SchoolTimetableConfig {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear String   @default("2025-26")
  daysJson     String   @db.Text

  @@unique([schoolId, academicYear])
  @@map("schooltimetableconfig")
}

model ClassTimetableRelease {
  id           String      @id @default(cuid())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  schoolId     String
  school       School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId      String
  class        SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  academicYear String      @default("2025-26")
  isReleased   Boolean     @default(false)
  releasedAt   DateTime?
  releasedBy   String?

  @@unique([schoolId, classId, academicYear])
  @@index([schoolId, academicYear, isReleased])
  @@map("classtimetablerelease")
}

model BulkSubmission {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  schoolId    String?
  school      School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  totalCount  Int
  successCount Int     @default(0)
  failedCount  Int     @default(0)
  status      String   @default("pending")
  studentIds  String   @db.Text
  results     String?  @db.Text

  @@index([schoolId])
  @@map("bulksubmission")
}

model AutomationJob {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  schoolId        String?
  school          School?   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  status          String    @default("pending")
  mode            String    @default("auto")
  actionMode      String    @default("auto")
  portalType      String    @default("sjed")
  studentIds      String    @db.Text
  currentIndex    Int       @default(0)
  currentStep     String?
  totalCount      Int       @default(0)
  completedCount  Int       @default(0)
  failedCount     Int       @default(0)
  logs            String?   @db.Text
  studentProgress String?   @db.Text
  startedAt       DateTime?
  finishedAt      DateTime?
  errorMessage    String?
  /** User/dashboard se OTP — automation auto-fill karega */
  otpCode         String?

  @@index([schoolId])
  @@index([status])
  @@index([createdAt])
  @@map("automationjob")
}

// ─── Financial Year (April–March, Indian FY) ───
model FinancialYear {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  label      String
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean  @default(false)
  isLocked   Boolean  @default(false)
  auditStatus String  @default("open")
  submittedAt DateTime?
  submittedById String?
  submittedBy User?   @relation("FySubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  submittedRemarks String? @db.Text

  accounts      Account[]
  vouchers      Voucher[]
  auditSessions CaAuditSession[]

  @@unique([schoolId, label])
  @@index([schoolId])
  @@map("financialyear")
}

// ─── Chart of Accounts (Indian school accounting) ───
model Account {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  schoolId        String
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  financialYearId String
  financialYear   FinancialYear @relation(fields: [financialYearId], references: [id], onDelete: Cascade)
  code            String
  name            String
  groupType       String
  accountType     String
  openingBalance  Float    @default(0)
  balanceType     String   @default("debit")
  isActive        Boolean  @default(true)
  parentId        String?

  voucherLines VoucherLine[]

  @@unique([schoolId, financialYearId, code])
  @@index([schoolId])
  @@index([financialYearId])
  @@index([groupType])
  @@map("account")
}

// ─── Voucher (Payment / Receipt / Journal / Contra) ───
model Voucher {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  schoolId        String
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  financialYearId String
  financialYear   FinancialYear @relation(fields: [financialYearId], references: [id], onDelete: Cascade)
  voucherNo       String
  voucherType     String
  voucherDate     DateTime
  narration       String   @db.Text
  totalAmount     Float
  referenceNo     String?
  partyName       String?
  paymentMode     String?
  chequeNo        String?
  bankName        String?
  billNo          String?
  billDate        DateTime?
  gstin           String?
  auditStatus     String   @default("pending")
  auditRemarks    String?  @db.Text
  auditedAt       DateTime?
  auditedBy       String?
  createdById     String?
  createdBy       User?    @relation("VoucherCreatedBy", fields: [createdById], references: [id])
  isPosted        Boolean  @default(true)

  lines VoucherLine[]

  @@unique([schoolId, financialYearId, voucherNo])
  @@index([schoolId])
  @@index([financialYearId])
  @@index([voucherType])
  @@index([auditStatus])
  @@index([voucherDate])
  @@map("voucher")
}

model VoucherLine {
  id          String  @id @default(cuid())
  voucherId   String
  voucher     Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  accountId   String
  account     Account @relation(fields: [accountId], references: [id])
  debit       Float   @default(0)
  credit      Float   @default(0)
  description String?

  @@index([voucherId])
  @@index([accountId])
  @@map("voucherline")
}

// ─── CA Audit Session ───
model CaAuditSession {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  schoolId        String
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  financialYearId String
  financialYear   FinancialYear @relation(fields: [financialYearId], references: [id], onDelete: Cascade)
  status          String   @default("in_progress")
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  caName          String?
  caMembershipNo  String?
  findings        String?  @db.Text
  recommendation  String?  @db.Text

  actions AuditAction[]

  @@index([schoolId])
  @@index([financialYearId])
  @@map("caauditsession")
}

model AuditAction {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  sessionId   String
  session     CaAuditSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entityType  String
  entityId    String?
  remarks     String?  @db.Text

  @@index([sessionId])
  @@map("auditaction")
}

// ─── CA ↔ School assignment (one CA firm, multiple schools) ───
model CaSchoolAssignment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  isPrimary Boolean  @default(false)

  @@unique([userId, schoolId])
  @@index([userId])
  @@index([schoolId])
  @@map("caschoolassignment")
}

// ─── Exams & Results ───
model Exam {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  schoolId        String
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name            String
  examType        String
  academicYear    String
  standard        String?
  term            String?
  section         String?
  maxMarks        Int      @default(100)
  passingMarks    Int      @default(33)
  reopeningDate   String?
  examDate        DateTime?
  /** JSON: mid exam count, per-term publish/lock/max marks — see exam-terms.ts */
  termMeta        String?  @db.Text
  isPublished     Boolean  @default(false)
  publishedAt     DateTime?

  subjects ExamSubject[]
  results  ExamResult[]

  @@index([schoolId])
  @@index([academicYear])
  @@map("exam")
}

model ExamSubject {
  id        String @id @default(cuid())
  examId    String
  exam      Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)
  name      String
  code      String?
  maxMarks  Int    @default(100)
  sortOrder Int    @default(0)

  results ExamResult[]

  @@index([examId])
  @@map("examsubject")
}

model ExamResult {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  subjectId   String
  subject     ExamSubject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  marksObtained    Float
  achievementMarks Float   @default(0)
  graceMarks       Float   @default(0)
  grade            String?
  isAbsent         Boolean @default(false)
  remarks          String?

  @@unique([examId, subjectId, studentId])
  @@index([studentId])
  @@index([examId])
  @@map("examresult")
}

model ReportCard {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examId       String?
  academicYear String
  standard          String
  section           String?
  totalMarks        Float?
  percentage        Float?
  grade             String?
  rank              Int?
  result            String?
  passNumber        String?
  attendancePresent Int?
  attendanceTotal   Int?
  reopeningDate     String?
  pdfPath           String?
  isPublished       Boolean  @default(false)

  @@index([studentId])
  @@index([academicYear])
  @@map("reportcard")
}

model ChatRoom {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  type      String
  name      String?
  directKey String?  @unique

  participants ChatParticipant[]
  messages     ChatMessage[]

  @@index([schoolId])
  @@index([schoolId, type])
  @@map("chatroom")
}

model ChatParticipant {
  id         String    @id @default(cuid())
  roomId     String
  room       ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?

  @@unique([roomId, userId])
  @@index([userId])
  @@map("chatparticipant")
}

model ChatMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  type      String   @default("text")
  content   String?  @db.Text

  attachments ChatAttachment[]

  @@index([roomId, createdAt])
  @@map("chatmessage")
}

model ChatAttachment {
  id        String      @id @default(cuid())
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileName  String
  mimeType  String
  filePath  String
  fileSize  Int

  @@map("chatattachment")
}

/** School-wide daily attendance register — one book per date */
model DailyAttendanceBook {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  dateIso       String
  academicYear  String
  dayOfWeek     String   @default("")
  workingDay    Int?
  shift         String   @default("")
  avgPercent    Float?
  principalSign String   @default("")
  rows          DailyAttendanceBookRow[]

  @@unique([schoolId, dateIso, academicYear])
  @@index([schoolId, dateIso])
  @@map("dailyattendancebook")
}

model DailyAttendanceBookRow {
  id           String              @id @default(cuid())
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  bookId       String
  book         DailyAttendanceBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
  classId      String?
  serial       Int
  standard     String              @default("")
  section      String              @default("")
  stream       String              @default("")
  presentBoys  Int                 @default(0)
  presentGirls Int                 @default(0)
  absentBoys   Int                 @default(0)
  absentGirls  Int                 @default(0)
  newAdmBoys   Int                 @default(0)
  newAdmGirls  Int                 @default(0)
  leftBoys     Int                 @default(0)
  leftGirls    Int                 @default(0)
  teacherSign  String              @default("")

  @@unique([bookId, classId])
  @@index([bookId])
  @@map("dailyattendancebookrow")
}

/**
 * In-app notifications for school panels (admin / teacher / clerk / ca).
 * Chat unread stays derived from ChatParticipant; this table covers student/data events + optional chat digests.
 */
model Notification {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  schoolId  String?
  school    School?   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /** chat | student | attendance | system | admission | result */
  type      String    @default("system")
  title     String
  body      String?   @db.Text
  href      String?
  /** Optional JSON meta (studentId, roomId, etc.) */
  metaJson  String?   @db.Text
  readAt    DateTime?

  @@index([userId, readAt, createdAt])
  @@index([schoolId, createdAt])
  @@index([userId, createdAt])
  @@map("notification")
}

/** Public landing “Contact support” form → super admin inbox */
model ContactSupportMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name       String
  email      String
  phone      String?
  schoolCode String?
  subject    String
  message    String   @db.Text
  /** new | read | resolved */
  status     String   @default("new")
  adminNote  String?  @db.Text

  @@index([status, createdAt])
  @@index([createdAt])
  @@map("contactsupportmessage")
}
