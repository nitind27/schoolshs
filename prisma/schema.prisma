generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model School {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  code      String   @unique
  district  String?
  address   String?
  phone     String?
  email     String?
  isActive  Boolean  @default(true)

  users           User[]
  students        Student[]
  staff           Staff[]
  classes         SchoolClass[]
  settings        SchoolSettings?
  bulkSubmissions BulkSubmission[]
  automationJobs  AutomationJob[]
  smsInbox        SmsInboxMessage[]
  financialYears  FinancialYear[]
  accounts        Account[]
  vouchers        Voucher[]
  exams           Exam[]
  auditSessions   CaAuditSession[]
  caAssignments   CaSchoolAssignment[]
  idCardShareLinks IdCardShareLink[]

  @@index([isActive])
  @@map("school")
}

model User {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  email        String    @unique
  passwordHash String
  name         String
  role         String
  schoolId     String?
  school       School?   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staffId      String?   @unique
  staff        Staff?    @relation(fields: [staffId], references: [id], onDelete: SetNull)
  studentId    String?   @unique
  student      Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?

  vouchersCreated Voucher[]      @relation("VoucherCreatedBy")
  auditActions    AuditAction[]
  caSchoolAssignments CaSchoolAssignment[]
  fySubmissions   FinancialYear[] @relation("FySubmittedBy")

  @@index([schoolId])
  @@index([role])
  @@map("user")
}

model SchoolSettings {
  id                 String @id @default(cuid())
  schoolId           String? @unique
  school             School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolName         String @default("My School")
  schoolAddress      String?
  schoolPhone        String?
  schoolEmail        String?
  academicYear       String @default("2025-26")
  logoPath           String?
  idCardPrimaryColor String @default("#e91e8c")
  idCardAccentColor  String @default("#1e3a8a")
  tagline            String?
  /** School SJED portal login — ek baar save, sab students ke liye same session */
  dgSjedUsername     String?
  dgSjedPassword     String?
  /** Post-Matric Citizen portal (optional) */
  dgCitizenLoginId   String?
  dgCitizenPassword  String?
  dgCitizenLoginMethod String? @default("mobile")
  /** Phone SMS webhook secret — SMS Forwarder app is token se connect */
  smsInboxToken      String?  @unique
  /** DG OTP wala registered mobile — phone bridge link is number se connect */
  dgOtpMobile        String?

  @@map("schoolsettings")
}

model IdCardShareLink {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  schoolId     String
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  slug         String    @unique
  username     String
  passwordHash String
  label        String?
  classId      String?
  standard     String?
  section      String?
  academicYear String    @default("2025-26")
  expiresAt    DateTime?
  isActive     Boolean   @default(true)
  lastAccessAt DateTime?
  accessCount  Int       @default(0)
  createdById  String?

  @@index([schoolId])
  @@map("idcardsharelink")
}

model SmsInboxMessage {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sender     String?
  body       String   @db.Text
  otpCode    String?
  consumed   Boolean  @default(false)

  @@index([schoolId, createdAt])
  @@index([schoolId, consumed])
  @@map("smsinboxmessage")
}

model Staff {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  schoolId      String?
  school        School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  employeeId    String?
  firstName     String
  lastName      String
  designation   String
  department    String?
  mobileNumber  String
  email         String?
  gender        String?
  dateOfJoining String?
  isActive      Boolean  @default(true)
  photoPath     String?
  classes       SchoolClass[] @relation("ClassTeacher")
  user          User?

  @@unique([schoolId, employeeId])
  @@index([schoolId])
  @@index([isActive])
  @@index([designation])
  @@map("staff")
}

model SchoolClass {
  id                  String   @id @default(cuid())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  schoolId            String?
  school              School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name                String
  standard            String
  section             String
  academicYear        String   @default("2025-26")
  institutionName     String?
  institutionDistrict String?
  classTeacherId      String?
  classTeacher        Staff?   @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  students            Student[]

  @@unique([schoolId, standard, section, academicYear])
  @@index([schoolId])
  @@index([standard])
  @@index([academicYear])
  @@map("schoolclass")
}

model Student {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  firstName        String
  middleName       String?
  surname          String
  aadhaarName      String
  dateOfBirth      String
  gender           String
  aadhaarNumber    String
  rationCardNumber String?
  mobileNumber     String
  email            String?
  motherName       String
  fatherName       String
  guardianName     String?
  category         String
  caste            String?
  religion         String
  maritalStatus    String  @default("Unmarried")
  parentOccupation String
  isOrphan         Boolean @default(false)
  annualFamilyIncome Float

  classId              String?
  schoolClass          SchoolClass? @relation(fields: [classId], references: [id])
  rollNumber           String?
  grNumber             String?
  section              String?
  standard             String?
  childUid             String?
  bloodGroup           String?
  idCardValidUpto      String?
  idPhotoProcessedPath String?

  currentAddress     String   @db.Text
  currentDistrict    String
  currentCity        String
  currentPincode     String
  permanentAddress   String   @db.Text
  permanentDistrict  String
  permanentCity      String
  permanentPincode   String
  habitationType     String  @default("Own")
  familySize         Int     @default(4)
  residentType       String  @default("Rural")
  isHosteler         Boolean @default(false)
  hostelType         String?
  hostelName         String?

  scholarshipScheme    String
  financialYear        String
  courseType           String
  courseName           String
  institutionDistrict  String
  institutionName      String
  currentYear          String
  admissionType        String  @default("Regular")
  startDate            String?
  completionDate       String?
  board10th            String
  percentage10th       Float
  year10th             String
  board12th            String?
  percentage12th       Float?
  year12th             String?
  previousQualification String?

  bankName          String
  branchName        String
  accountNumber     String
  ifscCode          String
  accountHolderName String

  dgLoginId       String?
  dgPassword      String?
  dgLoginMethod   String?  @default("mobile")

  photoPath           String?
  aadhaarDocPath      String?
  incomeCertPath      String?
  casteCertPath       String?
  marksheet10Path     String?
  marksheet12Path     String?
  bankPassbookPath    String?
  feeReceiptPath      String?

  lastAutomationAt    DateTime?
  lastAutomationLog   String?  @db.Text

  status           String  @default("draft")
  admissionStatus  String  @default("pending")
  verifiedAt       DateTime?
  verifiedBy       String?
  submissionDate   DateTime?
  notes            String?  @db.Text
  validationErrors String?  @db.Text

  user         User?
  examResults  ExamResult[]
  reportCards  ReportCard[]

  @@unique([schoolId, aadhaarNumber])
  @@index([schoolId])
  @@index([status])
  @@index([category])
  @@index([scholarshipScheme])
  @@index([classId])
  @@index([standard])
  @@index([section])
  @@map("student")
}

model BulkSubmission {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  schoolId    String?
  school      School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  totalCount  Int
  successCount Int     @default(0)
  failedCount  Int     @default(0)
  status      String   @default("pending")
  studentIds  String   @db.Text
  results     String?  @db.Text

  @@index([schoolId])
  @@map("bulksubmission")
}

model AutomationJob {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  schoolId        String?
  school          School?   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  status          String    @default("pending")
  mode            String    @default("auto")
  actionMode      String    @default("auto")
  portalType      String    @default("sjed")
  studentIds      String    @db.Text
  currentIndex    Int       @default(0)
  currentStep     String?
  totalCount      Int       @default(0)
  completedCount  Int       @default(0)
  failedCount     Int       @default(0)
  logs            String?   @db.Text
  studentProgress String?   @db.Text
  startedAt       DateTime?
  finishedAt      DateTime?
  errorMessage    String?
  /** User/dashboard se OTP — automation auto-fill karega */
  otpCode         String?

  @@index([schoolId])
  @@index([status])
  @@index([createdAt])
  @@map("automationjob")
}

// ─── Financial Year (April–March, Indian FY) ───
model FinancialYear {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  label      String
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean  @default(false)
  isLocked   Boolean  @default(false)
  auditStatus String  @default("open")
  submittedAt DateTime?
  submittedById String?
  submittedBy User?   @relation("FySubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  submittedRemarks String? @db.Text

  accounts      Account[]
  vouchers      Voucher[]
  auditSessions CaAuditSession[]

  @@unique([schoolId, label])
  @@index([schoolId])
  @@map("financialyear")
}

// ─── Chart of Accounts (Indian school accounting) ───
model Account {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  schoolId        String
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  financialYearId String
  financialYear   FinancialYear @relation(fields: [financialYearId], references: [id], onDelete: Cascade)
  code            String
  name            String
  groupType       String
  accountType     String
  openingBalance  Float    @default(0)
  balanceType     String   @default("debit")
  isActive        Boolean  @default(true)
  parentId        String?

  voucherLines VoucherLine[]

  @@unique([schoolId, financialYearId, code])
  @@index([schoolId])
  @@index([financialYearId])
  @@index([groupType])
  @@map("account")
}

// ─── Voucher (Payment / Receipt / Journal / Contra) ───
model Voucher {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  schoolId        String
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  financialYearId String
  financialYear   FinancialYear @relation(fields: [financialYearId], references: [id], onDelete: Cascade)
  voucherNo       String
  voucherType     String
  voucherDate     DateTime
  narration       String   @db.Text
  totalAmount     Float
  referenceNo     String?
  partyName       String?
  paymentMode     String?
  chequeNo        String?
  bankName        String?
  billNo          String?
  billDate        DateTime?
  gstin           String?
  auditStatus     String   @default("pending")
  auditRemarks    String?  @db.Text
  auditedAt       DateTime?
  auditedBy       String?
  createdById     String?
  createdBy       User?    @relation("VoucherCreatedBy", fields: [createdById], references: [id])
  isPosted        Boolean  @default(true)

  lines VoucherLine[]

  @@unique([schoolId, financialYearId, voucherNo])
  @@index([schoolId])
  @@index([financialYearId])
  @@index([voucherType])
  @@index([auditStatus])
  @@index([voucherDate])
  @@map("voucher")
}

model VoucherLine {
  id          String  @id @default(cuid())
  voucherId   String
  voucher     Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  accountId   String
  account     Account @relation(fields: [accountId], references: [id])
  debit       Float   @default(0)
  credit      Float   @default(0)
  description String?

  @@index([voucherId])
  @@index([accountId])
  @@map("voucherline")
}

// ─── CA Audit Session ───
model CaAuditSession {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  schoolId        String
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  financialYearId String
  financialYear   FinancialYear @relation(fields: [financialYearId], references: [id], onDelete: Cascade)
  status          String   @default("in_progress")
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  caName          String?
  caMembershipNo  String?
  findings        String?  @db.Text
  recommendation  String?  @db.Text

  actions AuditAction[]

  @@index([schoolId])
  @@index([financialYearId])
  @@map("caauditsession")
}

model AuditAction {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  sessionId   String
  session     CaAuditSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entityType  String
  entityId    String?
  remarks     String?  @db.Text

  @@index([sessionId])
  @@map("auditaction")
}

// ─── CA ↔ School assignment (one CA firm, multiple schools) ───
model CaSchoolAssignment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  isPrimary Boolean  @default(false)

  @@unique([userId, schoolId])
  @@index([userId])
  @@index([schoolId])
  @@map("caschoolassignment")
}

// ─── Exams & Results ───
model Exam {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  schoolId        String
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name            String
  examType        String
  academicYear    String
  standard        String?
  term            String?
  section         String?
  maxMarks        Int      @default(100)
  passingMarks    Int      @default(33)
  reopeningDate   String?
  examDate        DateTime?
  isPublished     Boolean  @default(false)
  publishedAt     DateTime?

  subjects ExamSubject[]
  results  ExamResult[]

  @@index([schoolId])
  @@index([academicYear])
  @@map("exam")
}

model ExamSubject {
  id        String @id @default(cuid())
  examId    String
  exam      Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)
  name      String
  code      String?
  maxMarks  Int    @default(100)
  sortOrder Int    @default(0)

  results ExamResult[]

  @@index([examId])
  @@map("examsubject")
}

model ExamResult {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  subjectId   String
  subject     ExamSubject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  marksObtained    Float
  achievementMarks Float   @default(0)
  graceMarks       Float   @default(0)
  grade            String?
  isAbsent         Boolean @default(false)
  remarks          String?

  @@unique([examId, subjectId, studentId])
  @@index([studentId])
  @@index([examId])
  @@map("examresult")
}

model ReportCard {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examId       String?
  academicYear String
  standard          String
  section           String?
  totalMarks        Float?
  percentage        Float?
  grade             String?
  rank              Int?
  result            String?
  passNumber        String?
  attendancePresent Int?
  attendanceTotal   Int?
  reopeningDate     String?
  pdfPath           String?
  isPublished       Boolean  @default(false)

  @@index([studentId])
  @@index([academicYear])
  @@map("reportcard")
}
